{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
  ],
  "schedule": [
    // Runs once, despite '*' minutes (https://docs.renovatebot.com/configuration-options/#schedule)
    "* 0-6 * * 1",
  ],
  "ignorePaths": [
    "**/test_resources/**",
  ],
  "dependencyDashboard": true,
  "branchConcurrentLimit": 0,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rebaseWhen": "behind-base-branch",
  // Remove configDescription from PR body
  "prBodyTemplate": "{{{header}}}{{{table}}}{{{warnings}}}{{{notes}}}{{{changelogs}}}{{{controls}}}{{{footer}}}",
  // Remove "dependency " prefix which makes message subjects too long
  "commitMessageTopic": "{{depName}}",
  "customManagers": [
    {
      "description": "Develocity API spec and library version (tracks gradle-enterprise Helm chart)",
      "customType": "regex",
      "fileMatch": ["^gradle\\.properties$"],
      "matchStrings": ["(?m)^(?<prefix>develocity\\.)?version=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "gradle-enterprise",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://helm.gradle.com",
      // Writes "develocity.version=2025.4" (prefix truthy → no patch)
      //    and "version=2025.4.0"          (prefix falsy  → appends patch)
      "autoReplaceStringTemplate": "{{prefix}}version={{newMajor}}.{{newMinor}}{{#unless prefix}}.{{newPatch}}{{/unless}}",
      "versioningTemplate": "semver-coerced",
    },
  ],
  "allowedCommands": [
    "^./gradlew :library:apiDump$",
  ],
  "postUpgradeTasks": {
    "commands": [
      "./gradlew :library:apiDump",
    ],
    "fileFilters": ["library/api/library.api"],
    "executionMode": "update",
  },
  "packageRules": [
    // Group Develocity plugin bumps; add changelog link
    {
      "matchDepNames": ["com.gradle.develocity", "com.gradle:develocity-gradle-plugin"],
      "prBodyNotes": ["https://docs.gradle.com/develocity/gradle-plugin/current#release_history"],
      "groupName": "Develocity Gradle plugin",
      "groupSlug": "develocity-gradle-plugin",
    },
    // Group Kotlin/Jupyter artifact bumps
    {
      "matchDepNames": [
        "org.jetbrains.kotlinx:kotlin-jupyter-test-kit",
        "org.jetbrains.kotlinx:kotlin-jupyter-api",
        // Two possible names for the plugin (GAV or plugin ID)
        "org.jetbrains.kotlinx:kotlin-jupyter-api-gradle-plugin",
        "org.jetbrains.kotlin.jupyter.api",
      ],
      "groupName": "Kotlin/Jupyter",
      "groupSlug": "kotlin-jupyter",
    },
    // Group bumps of .github/scripts dependencies
    {
      "matchFileNames": [".github/scripts/**"],
      "groupName": ".github/scripts dependencies",
    },
    // Group bumps of examples/ dependencies
    {
      "matchFileNames": ["examples/**"],
      "groupName": "examples dependencies",
    },
    // Disable patch updates for Develocity API spec
    {
      "matchDepNames": ["gradle-enterprise"],
      "matchUpdateTypes": ["patch"],
      "enabled": false,
      "prBodyNotes": ["https://docs.gradle.com/enterprise/api-manual/#release_history"],
    },
  ],
}
